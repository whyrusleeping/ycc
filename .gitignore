# secrets — never commit
ant-key
*.pem

# build artifacts (build to /tmp, not the source tree)
/ycc
/yccd
/ycc-spike
/cmd/*/ycc
/cmd/*/yccd

# session state + scratch
.ycc/
scratch/
lsp.webp

# iOS client (clients/ios): generated project + SPM/Xcode build detritus
clients/ios/*.xcodeproj
clients/ios/App/Info.plist
clients/ios/**/xcuserdata/
clients/ios/**/.build/
clients/ios/**/.swiftpm/
clients/ios/**/Package.resolved
.DS_Store
